}

enum Icone_profilEnum {
  Ico1
  Ico2
  Ico3
  Ico4
  Ico5
  Ico6
  Ico7
  Ico8
}

model Utilisateur {
  id_utilisateur   Int              @id @default(autoincrement())
  pseudo           String           @unique
  nom              String
  prenom           String
  date_naissance   DateTime
  adresse_email    String           @unique
  mot_de_passe     String
  description      String
  date_inscription DateTime         @default(now())
  icone_profil     Icone_profilEnum @default(Ico1)

  amitiesEnvoyees Ami[]        @relation(name: "AmitieUtilisateur1")
  amitiesRecues   Ami[]        @relation(name: "AmitieUtilisateur2")
  forums          Forum[]
  ludotheques     Ludotheque[]
}

model Ami {
  utilisateur_1   Utilisateur @relation(name: "AmitieUtilisateur1", fields: [id_utilisateur1], references: [id_utilisateur])
  id_utilisateur1 Int

  utilisateur_2   Utilisateur @relation(name: "AmitieUtilisateur2", fields: [id_utilisateur2], references: [id_utilisateur])
  id_utilisateur2 Int

  @@id([id_utilisateur1, id_utilisateur2]) // Clé primaire composite
}

model Jeux {
  id_jeux          Int             @id @default(autoincrement())
  nom              String          @unique
  src_image        String
  date_publication DateTime
  tags             TagJeu[] // Utilisation de la table de relation
  studio           StudioJeu[]
  plateformes      PlateformeJeu[]
  editeur          EditeurJeu[]
  note             Float
  any_pourcent     Float
  main_plus_extra  Float
  completionniste  Float
  allStyle         Float
  description      String
  nb_favoris       Int

  forums      Forum[]
  ludotheques Ludotheque[]
}

model Forum {
  utilisateur      Utilisateur @relation(fields: [id_utilisateur], references: [id_utilisateur])
  id_utilisateur   Int
  jeux             Jeux        @relation(fields: [id_jeux], references: [id_jeux])
  id_jeux          Int
  commentaire      String
  titre            String
  date_publication DateTime    @default(now())

  @@id([id_utilisateur, id_jeux]) // Clé primaire composite
}

model Ludotheque {
  id_utilisateur Int
  id_jeux        Int

  utilisateur Utilisateur @relation(fields: [id_utilisateur], references: [id_utilisateur])
  jeux        Jeux        @relation(fields: [id_jeux], references: [id_jeux])

  statut          StatutEnum          @default(NON_DEFINI)
  Type_completion Type_completionEnum @default(NON_DEFINI)
  commentaire     String
  note            Float

  @@id([id_utilisateur, id_jeux]) // Clé primaire composite
}

model Tag {
  id   Int      @id @default(autoincrement())
  name TagEnum
  jeux TagJeu[]
}

model TagJeu {
  tagId Int
  jeuId Int
  tag   Tag  @relation(fields: [tagId], references: [id])
  jeu   Jeux @relation(fields: [jeuId], references: [id_jeux])

  @@id([tagId, jeuId]) // Définir la relation many-to-many
}

model Studio {
  id   Int         @id @default(autoincrement())
  name StudioEnum
  jeux StudioJeu[]
}

model StudioJeu {
  studioId Int
  jeuId    Int
  studio   Studio @relation(fields: [studioId], references: [id])
  jeu      Jeux   @relation(fields: [jeuId], references: [id_jeux])

  @@id([studioId, jeuId])
}

model Plateforme {
  id   Int             @id @default(autoincrement())
  name PlateformeEnum
  jeux PlateformeJeu[]
}

model PlateformeJeu {
  plateformeId Int
  jeuId        Int
  plateforme   Plateforme @relation(fields: [plateformeId], references: [id])
  jeu          Jeux       @relation(fields: [jeuId], references: [id_jeux])
  Editeur      Editeur?   @relation(fields: [editeurId], references: [id])
  editeurId    Int?

  @@id([plateformeId, jeuId])
}

model Editeur {
  id         Int             @id @default(autoincrement())
  name       EditeurEnum
  jeux       PlateformeJeu[]
  EditeurJeu EditeurJeu[]
}

model EditeurJeu {
  EditeurId Int
  jeuId     Int
  editeur   Editeur @relation(fields: [EditeurId], references: [id])
  jeu       Jeux    @relation(fields: [jeuId], references: [id_jeux])

  @@id([EditeurId, jeuId])
}
